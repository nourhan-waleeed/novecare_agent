<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!-- Tree View -->
    <record id="view_incoming_leads_tree" model="ir.ui.view">
        <field name="name">incoming.leads.tree</field>
        <field name="model">incoming.leads</field>
        <field name="arch" type="xml">
            <tree string="Incoming Leads" sample="1">
                <field name="lead_first_name"/>
                <field name="lead_last_name"/>
                <field name="lead_phone_no"/>
                <field name="email"/>
                <field name="stages"/>
                <field name="segment"/>
                <field name="source"/>
                <field name="lead_date"/>
                <field name="partner_id"/>
                <field name="create_date"/>
            </tree>
        </field>
    </record>

<record id="view_incoming_leads_form" model="ir.ui.view">
    <field name="name">incoming.leads.form</field>
    <field name="model">incoming.leads</field>
    <field name="arch" type="xml">
        <form string="Incoming Lead">
            <header>
                <button name="action_book_appointment" string="Book Appointment" type="object" class="oe_highlight"/>
            </header>
            <sheet>
                <div class="oe_title">
                    <h1>
                        <field name="lead_first_name" placeholder="First Name" style="width: 50%;"/>
<!--                        <field name="lead_last_name" placeholder="Last Name" style="width: 100%;"/>-->
                    </h1>
                    <h3 class="text-muted">
                        <field name="partner_id" readonly="1" />
                    </h3>
                    <field name="segment" placeholder="Segment"/>
                </div>

                <!-- Split screen layout -->
                <div style="display: flex; margin-top: 20px;">
                    <!-- Left column - Contact Panel (30%) with styled border -->
                    <div style="flex: 0 0 30%; margin-right: 20px; border-radius: 8px; overflow: hidden; box-shadow: 0 2px 8px rgba(0,0,0,0.1);">
                        <!-- Teal header -->
                        <div style="background-color: #00796b; color: white; padding: 15px;">
                            <div style="display: flex; align-items: center;">
                                <div style="width: 50px; height: 50px; background-color: white; border-radius: 50%; display: flex; align-items: center; justify-content: center; margin-right: 15px;">
                                    <i class="fa fa-user" style="color: #00796b; font-size: 24px;"/>
                                </div>
                                <div>
                                    <div class="d-flex fs-6">
                                        <field name="lead_first_name"/>
                                        <field name="lead_last_name"/>
                                    </div>
<!--                                    <h3 style="margin: 0; font-size: 16px;color: white;"><field name="lead_first_name"/> <field name="lead_last_name"/></h3>-->
                                    <div style="font-size: 13px;">ID: DERM-<field name="id"/></div>
                                    <div class="badge" style="background-color: #e91e63; color: white; font-size: 16px; padding: 3px 8px; border-radius: 12px; margin-top: 3px;">
                                        <field name="segment" placeholder="Segment"/>
                                    </div>
                                </div>
                            </div>
                        </div>

                        <div style="background-color: white; padding: 15px;">
                            <!-- WhatsApp and Contact Info buttons -->
                            <div style="display: flex; gap: 10px; margin-bottom: 15px;">
                                <button name="original_lead_info" type="object" class="btn btn-secondary" style="flex: 1;">
                                    <i class="fa fa-user"/> Call
                                </button>
                                <button name="whatsapp_view" type="object" class="btn btn-success" style="flex: 1; background-color: #25D366; border-color: #25D366;">
                                    <i class="fa fa-whatsapp"/> Chat
                                </button>
                            </div>

                            <!-- Contact information fields with increased width -->
                            <group>
                                <group string="Phone Number" col="1">
                                    <field name="lead_phone_no" nolabel="1" placeholder="Phone Number"/>
                                </group>

                                <group string="Email" col="1">
                                    <field name="email" nolabel="1" placeholder="Email Address"/>
                                </group>

                                <group string="Preferred Contact Method" col="1">
                                    <field name="preferred_contact_method" readonly="1" placeholder="Preferred Contact Method" nolabel="1"/>
                                </group>

                                <group string="Gender" col="1">
                                    <field name="lead_gender" placeholder="Gender" nolabel="1" readonly="1"/>
                                </group>

                                <group string="Date of Birth" col="1">
                                    <field name="lead_dob" placeholder="Date of Birth" nolabel="1" readonly="1"/>
                                </group>

                                <group string="Assigned Agent" col="1">
                                    <field name="partner_id" nolabel="1"/>
                                </group>

                                <group string="Stages" col="1">
                                    <field name="stages" widget="radio" placeholder="Stages" nolabel="1" readonly="1"/>
                                </group>

                                <group string="Status" col="1" invisible="stages != 'lead'">
                                    <field name="lead_status" placeholder="Status" nolabel="1" readonly="1"/>
                                </group>

                                <group string="Status" col="1" invisible="stages != 'patient'">
                                    <field name="patient_status" placeholder="Status" readonly="1" nolabel="1"/>
                                </group>

                                <group string="Status" col="1" invisible="stages != 'won'">
                                    <field name="won_status" placeholder="Status" readonly="1" nolabel="1"/>
                                </group>
                            </group>
                        </div>
                    </div>

                    <!-- Right column - Main Content (70%) -->
                    <div style="flex: 1; border-radius: 8px; overflow: hidden; box-shadow: 0 2px 8px rgba(0,0,0,0.1);">
                        <div style="background-color: #00796b; color: white; padding: 15px;">
                            <h3 style="margin: 0; font-size: 16px; color: white;">Lead Information</h3>
                        </div>
                        <div style="background-color: white; padding: 15px;">
                            <field name="stages" widget="statusbar"
                                   statusbar_visible="lead,patient,won" options="{'clickable' : '1'}"/>

                            <notebook>
                                <page string="Lead Information" name="lead_info">
                                    <!-- Stage visualization (Lead/Patient/Won) -->
                                    <div style="display: flex; justify-content: space-around; margin-bottom: 20px;">
                                        <div style="text-align: center;">
                                            <div style="width: 50px; height: 50px; border-radius: 50%; background-color: #00a09d; color: white; display: flex; align-items: center; justify-content: center; margin: 0 auto;">
                                                <i class="fa fa-user"/>
                                            </div>
                                            <div style="margin-top: 5px;">Lead</div>
                                        </div>
                                        <div style="text-align: center;">
                                            <div style="width: 50px; height: 50px; border-radius: 50%; background-color: #f1f1f1; color: #6c757d; display: flex; align-items: center; justify-content: center; margin: 0 auto;">
                                                <i class="fa fa-user-md"/>
                                            </div>
                                            <div style="margin-top: 5px;">Patient</div>
                                        </div>
                                        <div style="text-align: center;">
                                            <div style="width: 50px; height: 50px; border-radius: 50%; background-color: #f1f1f1; color: #6c757d; display: flex; align-items: center; justify-content: center; margin: 0 auto;">
                                                <i class="fa fa-check-circle"/>
                                            </div>
                                            <div style="margin-top: 5px;">Closed Won</div>
                                        </div>
                                    </div>

                                    <group>
                                        <group string="Stage Information" col="1">
                                            <field name="stages" string="Stage"/>
                                            <field name="lead_status" invisible="stages != 'lead'" string="Lead Status"/>
                                            <field name="patient_status" invisible="stages != 'patient'" string="Patient Status"/>
                                            <field name="won_status" invisible="stages != 'won'" string="Won Status"/>
                                            <field name="segment" string="Segment"/>
                                        </group>
                                        <group string="Additional Details" col="1">
                                            <field name="source" string="Source"/>
                                            <field name="lead_date" string="Lead Date"/>
                                            <field name="reason" string="Reason"/>
                                            <field name="partner_id" string="Assigned Agent"/>
                                        </group>
                                    </group>

                                    <group string="TREATMENT INTEREST" col="1">
                                        <field name="reason_for_visit" nolabel="1" placeholder="Describe treatment interests, concerns, and inquiry details..."/>
                                    </group>
                                </page>

                                <page string="Lead Demographics" name="demographics">
                                    <group>
                                        <group string="Personal Information" col="1">
                                            <field name="lead_first_name" string="First Name"/>
                                            <field name="lead_last_name" string="Last Name"/>
                                            <field name="lead_gender" string="Gender"/>
                                            <field name="lead_dob" string="Date of Birth"/>
                                        </group>
                                        <group string="Contact Information" col="1">
                                            <field name="lead_phone_no" widget="phone" string="Phone Number"/>
                                            <field name="email" widget="email" string="Email"/>
                                            <field name="preferred_contact_method" string="Preferred Contact Method"/>
                                        </group>
                                    </group>
                                </page>


                                <page string="Activity Logs" name="activity_log">
                                </page>
                            </notebook>
                        </div>
                    </div>
                </div>
            </sheet>
        </form>
    </field>
</record>
    <record id="view_incoming_leads_kanban" model="ir.ui.view">
        <field name="name">incoming.leads.kanban</field>
        <field name="model">incoming.leads</field>
        <field name="arch" type="xml">
            <kanban default_group_by="stages" class="o_kanban_small_column" sample="1"
                   quick_create="false" records_draggable="1">
                <field name="lead_first_name"/>
                <field name="lead_last_name"/>
                <field name="lead_phone_no"/>
                <field name="email"/>
                <field name="stages"/>
                <field name="lead_status"/>
                <field name="patient_status"/>
                <field name="won_status"/>
                <field name="segment"/>
                <field name="source"/>
                <field name="lead_date"/>
                <field name="partner_id"/>
                <field name="lead_gender"/>
                <field name="lead_dob"/>
                <templates>
                    <t t-name="kanban-box">
                        <div t-attf-class="oe_kanban_global_click o_kanban_record_has_image_fill">
                            <div class="o_kanban_image_fill_left d-none d-md-block"
                                 t-attf-style="background-color: #{kanban_color(record.stages.raw_value)}">
                                <div class="o_kanban_image d-flex align-items-center justify-content-center">
                                    <i t-if="record.lead_gender.raw_value == 'Male'" class="fa fa-male fa-3x text-white"/>
                                    <i t-elif="record.lead_gender.raw_value == 'Female'" class="fa fa-female fa-3x text-white"/>
                                    <i t-else="" class="fa fa-user fa-3x text-white"/>
                                </div>
                                <div class="o_kanban_image_overlay p-2">
                                    <span class="badge rounded-pill"
                                          t-attf-style="background-color: #dc3545;">
                                        <t t-esc="record.segment.value"/>
                                    </span>
                                </div>
                            </div>
                            <div class="oe_kanban_details d-flex flex-column">
                                <div class="o_kanban_record_top">
                                    <div class="o_kanban_record_headings">
                                        <strong class="o_kanban_record_title">
                                            <t t-esc="record.lead_first_name.value"/> <t t-esc="record.lead_last_name.value"/>
                                        </strong>
                                        <small class="text-muted">
                                            <i class="fa fa-phone-alt me-1"/>
                                            <t t-esc="record.lead_phone_no.value"/>
                                        </small>
                                    </div>
                                </div>
                                <div class="o_kanban_record_body mt-2">
                                    <div t-if="record.stages.raw_value == 'lead'">
                                        <strong class="text-primary">Status:</strong> <t t-esc="record.lead_status.value"/>
                                    </div>
                                    <div t-elif="record.stages.raw_value == 'patient'">
                                        <strong class="text-success">Status:</strong> <t t-esc="record.patient_status.value"/>
                                    </div>
                                    <div t-elif="record.stages.raw_value == 'won'">
                                        <strong class="text-success">Status:</strong> <t t-esc="record.won_status.value"/>
                                    </div>
                                    <div class="mt-1">
                                        <small t-if="record.source.value"><i class="fa fa-hashtag me-1"/>Source: <t t-esc="record.source.value"/></small>
                                    </div>
                                    <div class="mt-1">
                                        <small t-if="record.lead_date.value"><i class="fa fa-calendar me-1"/>Lead Date: <t t-esc="record.lead_date.value"/></small>
                                    </div>
                                </div>
                                <div class="o_kanban_record_bottom mt-2">
                                    <div class="oe_kanban_bottom_left">
                                        <small><i class="fa fa-user-tie me-1"/>Call Center Agent: <t t-esc="record.partner_id.value"/></small>
                                    </div>
                                    <div class="oe_kanban_bottom_right">
                                        <a name="whatsapp_view" type="object" class="btn btn-sm btn-success">
                                            <i class="fa fa-whatsapp"/>
                                        </a>
                                    </div>
                                </div>
                            </div>
                        </div>
                    </t>
                </templates>
            </kanban>
        </field>
    </record>

    <!-- Search View -->
    <record id="view_incoming_leads_search" model="ir.ui.view">
        <field name="name">incoming.leads.search</field>
        <field name="model">incoming.leads</field>
        <field name="arch" type="xml">
            <search string="Search Incoming Leads">
                <field name="lead_first_name"/>
                <field name="lead_last_name"/>
                <field name="lead_phone_no"/>
                <field name="email"/>
                <field name="partner_id"/>
                <separator/>
                <filter string="Leads" name="stage_lead" domain="[('stages', '=', 'lead')]"/>
                <filter string="Patients" name="stage_patient" domain="[('stages', '=', 'patient')]"/>
                <filter string="Closed Won" name="stage_won" domain="[('stages', '=', 'won')]"/>
                <separator/>
                <filter string="Need Second Call" name="status_2nd_call" domain="[('lead_status', '=', 'need_2nd_call')]"/>
                <filter string="Need Third Call" name="status_3rd_call" domain="[('lead_status', '=', 'need_3rd_call')]"/>
                <filter string="Book Appointment" name="status_book_appointment" domain="[('lead_status', '=', 'book_appointment')]"/>
                <separator/>
                <filter string="High Price" name="segment_high_price" domain="[('segment.name', '=', 'High Price')]"/>
                <separator/>
                <filter string="My Leads" name="my_leads" domain="[('partner_id', '=', uid)]"/>
                <filter string="Leads Created Today" name="created_today" domain="[('create_date', '>=', context_today().strftime('%Y-%m-%d'))]"/>
                <group expand="0" string="Group By">
                    <filter string="Stage" name="group_by_stage" domain="[]" context="{'group_by': 'stages'}"/>
                    <filter string="Status (Lead)" name="group_by_lead_status" domain="[('stages', '=', 'lead')]" context="{'group_by': 'lead_status'}"/>
                    <filter string="Status (Patient)" name="group_by_patient_status" domain="[('stages', '=', 'patient')]" context="{'group_by': 'patient_status'}"/>
                    <filter string="Status (Won)" name="group_by_won_status" domain="[('stages', '=', 'won')]" context="{'group_by': 'won_status'}"/>
                    <filter string="Segment" name="group_by_segment" domain="[]" context="{'group_by': 'segment'}"/>
                    <filter string="Source" name="group_by_source" domain="[]" context="{'group_by': 'source'}"/>
                    <filter string="Lead Date" name="group_by_lead_date" domain="[]" context="{'group_by': 'lead_date'}"/>
                    <filter string="Assigned Agent" name="group_by_agent" domain="[]" context="{'group_by': 'partner_id'}"/>
                </group>
            </search>
        </field>
    </record>

    <record id="action_incoming_leads" model="ir.actions.act_window">
        <field name="name">Lead Journey</field>
        <field name="res_model">incoming.leads</field>
        <field name="view_mode">kanban,tree,form</field>
        <field name="search_view_id" ref="view_incoming_leads_search"/>
<!--        <field name="context">{'search_default_stage_lead': 1}</field>-->
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">
                Create your first lead!
            </p>
            <p>
                Track potential patients through their journey from lead to patient.
            </p>
        </field>
    </record>
    <record id="action_segments" model="ir.actions.act_window">
        <field name="name">Lead Journey</field>
        <field name="res_model">incoming.leads</field>
        <field name="view_mode">tree,form</field>
        <field name="search_view_id" ref="view_incoming_leads_search"/>
        <field name="context">{'search_default_group_by_segment': 1}</field>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">
                Create your first lead!
            </p>
            <p>
                Track potential patients through their journey from lead to patient.
            </p>
        </field>
    </record>



    <record id="action_book_appointment_wizard" model="ir.actions.act_window">
        <field name="name">Book Appointment</field>
        <field name="res_model">appointment.model</field>
        <field name="view_mode">form</field>
        <field name="target">new</field>
        <field name="context">{'default_lead_id': active_id}</field>
    </record>
</odoo>
